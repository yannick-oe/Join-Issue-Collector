    {
      "parameters": {
        "jsCode": "const message = $json;\n\nconst headers = message.payload?.headers || [];\nconst getHeader = (name) => {\n  return headers.find((header) => header.name.toLowerCase() === name.toLowerCase())?.value || \"\";\n};\n\nconst decodeBase64Url = (value = \"\") => {\n  const normalized = value.replace(/-/g, \"+\").replace(/_/g, \"/\");\n  return Buffer.from(normalized, \"base64\").toString(\"utf8\");\n};\n\nconst getBody = (payload) => {\n  if (payload?.body?.data) return decodeBase64Url(payload.body.data);\n  const parts = payload?.parts || [];\n  const textPart = parts.find((part) => part.mimeType === \"text/plain\");\n  if (textPart?.body?.data) return decodeBase64Url(textPart.body.data);\n  const htmlPart = parts.find((part) => part.mimeType === \"text/html\");\n  if (htmlPart?.body?.data) return decodeBase64Url(htmlPart.body.data).replace(/<[^>]*>/g, \" \");\n  return message.snippet || \"\";\n};\n\nconst fromRaw = getHeader(\"From\") || message.From || message.from || \"\";\nconst subject = getHeader(\"Subject\") || message.Subject || message.subject || \"Join Feature Request\";\n\nconst emailMatch = fromRaw.match(/<([^>]+)>/) || fromRaw.match(/[^\\s<>]+@[^\\s<>]+/);\nconst senderEmail = Array.isArray(emailMatch) ? emailMatch[1] || emailMatch[0] : \"\";\nconst senderName = fromRaw.replace(/<[^>]+>/g, \"\").replace(/\"/g, \"\").trim() || senderEmail;\n\nreturn [{\n  json: {\n    messageId: message.id,\n    threadId: message.threadId,\n    senderName,\n    senderEmail,\n    subject,\n    body: getBody(message.payload),\n    receivedAt: new Date().toISOString(),\n    today: new Date().toISOString().slice(0, 10)\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        256,
        0
      ],
      "id": "4442a7a7-300b-4e8b-bd85-c272d4b190bc",
      "name": "Normalize Email"
    },
    {
      "parameters": {
        "jsCode": "const mail = $json;\n\nconst buildTitle = (subject = \"\", body = \"\") => {\n  if (subject && subject !== \"Join Feature Request\") {\n    return subject.trim();\n  }\n\n  return body\n    .split(\"\\n\")\n    .find((line) => line.trim().length > 10)\n    ?.slice(0, 60)\n    || \"New Stakeholder Request\";\n};\n\nconst buildDescription = (body = \"\") => {\n  return body.trim();\n};\n\nconst buildPriority = (text = \"\") => {\n  const normalized = text.toLowerCase();\n\n  if (\n    normalized.includes(\"urgent\") ||\n    normalized.includes(\"critical\") ||\n    normalized.includes(\"asap\")\n  ) {\n    return \"urgent\";\n  }\n\n  if (\n    normalized.includes(\"low\") ||\n    normalized.includes(\"minor\")\n  ) {\n    return \"low\";\n  }\n\n  return \"medium\";\n};\n\nconst createTaskId = () => {\n  return `task-${Date.now()}-${Math.random()\n    .toString(36)\n    .slice(2, 8)}`;\n};\n\nreturn [\n  {\n    json: {\n      id: createTaskId(),\n      title: buildTitle(mail.subject, mail.body),\n      description: buildDescription(mail.body),\n      category: \"Technical Task\",\n      priority: buildPriority(mail.body),\n      status: \"triage\",\n      dueDate: \"\",\n      createdAt: new Date().toISOString(),\n\n      creatorType: \"external\",\n      creatorName: mail.senderName,\n      creatorEmail: mail.senderEmail,\n\n      isEmailRequest: true,\n      aiGenerated: true,\n      requestSource: \"email\",\n\n      assignedTo: [],\n      subtasks: [],\n\n      requestStatus: \"new\",\n      requestReceivedAt: mail.receivedAt\n    }\n  }\n];"
      },
