    {
      "parameters": {
        "jsCode": "const requests = $json || {};\n\nconst senderEmail =\n  $(\"Normalize Email\").first().json.senderEmail;\n\nconst today =\n  $(\"Normalize Email\").first().json.today;\n\nconst requestList = Object.values(requests);\n\nconst dailyRequests = requestList.filter((request) => {\n  return (\n    request.creatorEmail === senderEmail &&\n    request.requestReceivedAt?.startsWith(today)\n  );\n});\n\nreturn [\n  {\n    json: {\n      senderEmail,\n      today,\n      requestCount: dailyRequests.length,\n      limitReached: dailyRequests.length >= 10\n    }\n  }\n];"
      },
